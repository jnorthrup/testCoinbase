# Coinbase Advanced API key (defaults to ~/.cdp/cdp_api_key.json)
# COINBASE_API_KEY_FILE=~/.cdp/cdp_api_key.json

# Override key name + secret directly (alternative to _FILE)
# COINBASE_API_KEY_NAME=organizations/.../apiKeys/...
# COINBASE_API_KEY_SECRET=-----BEGIN EC PRIVATE KEY-----\n...

# Required for live trading (order placement)
# Without this, --place-strategy refuses to execute orders
ALLOW_LIVE_TRADE=1

# Optional: force read-only mode even if other flags are set
# WORM_READ_ONLY=1

# Optional: override Coinbase API host (defaults to api.coinbase.com)
# COINBASE_API_HOST=api.coinbase.com